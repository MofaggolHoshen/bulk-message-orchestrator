{
  "ConnectionStrings": {
    "SqlServer": "",
    "Hangfire": "",
    "AzureServiceBus": ""
  },
  "BulkPublishing": {
    "DefaultBatchSize": 1000,
    "MaxParallelPublishes": 16,
    "RetryCount": 3
  },
  "RecurringSchedules": [
    {
      "Id": "hourly-health-probe",
      "Cron": "0 * * * *",
      "Enabled": true
    },
    {
      "Id": "month-end-audit",
      "Cron": "0 2 L * *",
      "Enabled": true
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
